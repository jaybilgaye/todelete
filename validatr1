That’s a very good idea 👍 — in production we often create a “validation DAG” before the real Spark DAG to ensure:

env variables from env_subscriber are loaded correctly

Spark properties_file values are readable

paths like APP_COMMON_FILES_HOME, APP_HOME, etc. are resolved

no missing configs before submitting Spark


This avoids debugging failures after Spark starts.

Below is a safe validation DAG that:

1️⃣ loads the env file
2️⃣ reads the Spark properties file
3️⃣ prints everything in Airflow logs
4️⃣ fails if anything is missing


---

📄 Validation DAG File

Create file:

/app/airflow/airflow/dags/omega_iplogs_config_validation_dag.py


---

from airflow import DAG
from airflow.operators.python import PythonOperator
from datetime import datetime


ENV_FILE = "/opt/telstra/omega/omega-common-files/env_subscriber"

PROPERTIES_FILE = "/opt/telstra/omega/config/iplogs_spark.properties"


# ---------------------------------------------------
# Load env variables
# ---------------------------------------------------
def load_env_file(file_path):

    env_vars = {}

    with open(file_path) as f:

        for line in f:

            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if "=" in line:
                key, value = line.split("=", 1)
                env_vars[key.strip()] = value.strip()

    return env_vars


# ---------------------------------------------------
# Load spark properties
# ---------------------------------------------------
def load_properties(file_path):

    props = {}

    with open(file_path) as f:

        for line in f:

            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if "=" in line:
                key, value = line.split("=", 1)
                props[key.strip()] = value.strip()

    return props


# ---------------------------------------------------
# Validation function
# ---------------------------------------------------
def validate_config():

    print("\n===== Loading Environment Variables =====")

    env_vars = load_env_file(ENV_FILE)

    for k, v in env_vars.items():
        print(f"{k} = {v}")


    print("\n===== Loading Spark Properties =====")

    props = load_properties(PROPERTIES_FILE)

    for k, v in props.items():
        print(f"{k} = {v}")


    print("\n===== Basic Validation =====")


    required_env = [
        "APP_HOME",
        "APP_COMMON_FILES_HOME",
        "SPARK_HOME",
        "HADOOP_HOME",
        "HBASE_HOME"
    ]


    for var in required_env:

        if var not in env_vars:
            raise Exception(f"Missing ENV variable: {var}")

        print(f"{var} OK")


    required_props = [
        "spark.executor.memory",
        "spark.executor.instances",
        "spark.executor.cores"
    ]


    for p in required_props:

        if p not in props:
            raise Exception(f"Missing Spark property: {p}")

        print(f"{p} OK")


    print("\n✅ Environment + Spark properties validation successful")


# ---------------------------------------------------
# DAG definition
# ---------------------------------------------------
with DAG(

    dag_id="omega_iplogs_config_validation",

    start_date=datetime(2026, 1, 1),

    schedule_interval=None,

    catchup=False,

    tags=["spark", "validation", "omega"]

) as dag:


    validate_environment = PythonOperator(

        task_id="validate_env_and_properties",

        python_callable=validate_config

    )


