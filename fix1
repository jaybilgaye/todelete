from airflow import DAG
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator
from airflow.operators.python import PythonOperator
from datetime import datetime
import subprocess


def load_env_file(file_path):

    env_vars = {}

    with open(file_path) as f:

        for line in f:

            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if line.startswith("export"):
                line = line.replace("export ", "", 1)

            if "=" in line:
                key, value = line.split("=", 1)
                env_vars[key.strip()] = value.strip()

    return env_vars


def load_properties(file_path, env_vars):

    props = {}

    with open(file_path) as f:

        for line in f:

            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if "=" in line:

                key, value = line.split("=", 1)

                for k, v in env_vars.items():
                    value = value.replace("${"+k+"}", v)

                props[key.strip()] = value.strip()

    return props


env_vars = load_env_file(
    "/opt/telstra/omega/omega-common-files/env_subscriber"
)


spark_conf = load_properties(
    "/opt/telstra/omega/config/iplogs_spark.properties",
    env_vars
)


def check_if_running():

    app_name = "omega-IRqF-internetRequest-iplogs"

    cmd = "yarn application -list -appStates RUNNING"

    result = subprocess.check_output(cmd, shell=True).decode()

    if app_name in result:
        raise Exception(f"Spark job already running: {app_name}")



with DAG(

    dag_id="omega_iplogs_streaming",

    start_date=datetime(2026,1,1),

    schedule=None,

    catchup=False,

    tags=["spark","omega"]

) as dag:


    check_running = PythonOperator(

        task_id="check_if_spark_running",

        python_callable=check_if_running

    )


    run_spark_job = SparkSubmitOperator(

        task_id="submit_omega_iplogs",

        conn_id="spark_yarn",

        application="/opt/telstra/omega/internetrequestquery/current/irqf.jar",

        java_class="com.telstra.omega.process.omegaProcessRequest",

        name="omega-IRqF-internetRequest-iplogs",

        master="yarn",

        deploy_mode="cluster",

        conf=spark_conf,

        files="""
/opt/telstra/omega/omega-common-files/log4j-irqf/irqf-IPLOGS-log4j-executor.properties,
/opt/telstra/omega/omega-common-files/log4j-irqf/irqf-IPLOGS-log4j-driver.properties,
/opt/hbase/conf/hbase-site.xml
""",

        jars="""
/opt/telstra/omega/internetrequestquery/current/spark-internetRequest.jar,
/app/hbase/lib/hbase-client.jar,
/app/cluster-essentials/*
""",

        executor_memory="5g",

        executor_cores=2,

        num_executors=3,

        env_vars=env_vars,

        verbose=True

    )


    check_running >> run_spark_job


