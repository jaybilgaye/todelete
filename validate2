Below is a complete production-ready DAG file for your job using the architecture we discussed:

• SparkSubmitOperator
• env variables loaded from env_subscriber (Method 2)
• Spark configs stored in a properties_file (recommended for your ~40 configs)

This keeps the DAG clean and maintainable.


---

📄 DAG File

Create file:

/app/airflow/airflow/dags/omega_iplogs_spark_dag.py


---

from airflow import DAG
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator
from datetime import datetime


# ----------------------------------------------------
# Function to load env variables from env_subscriber
# ----------------------------------------------------
def load_env_file(file_path):

    env_vars = {}

    with open(file_path) as f:

        for line in f:

            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if "=" in line:
                key, value = line.split("=", 1)
                env_vars[key.strip()] = value.strip()

    return env_vars


# ----------------------------------------------------
# Load environment variables
# ----------------------------------------------------
env_vars = load_env_file(
    "/opt/telstra/omega/omega-common-files/env_subscriber"
)


# ----------------------------------------------------
# DAG definition
# ----------------------------------------------------
with DAG(

    dag_id="omega_iplogs_streaming",

    start_date=datetime(2026, 1, 1),

    schedule_interval=None,

    catchup=False,

    tags=["spark", "omega", "iplogs"]

) as dag:


    spark_submit_job = SparkSubmitOperator(

        task_id="submit_omega_iplogs",

        conn_id="spark_yarn",

        # -----------------------------------------
        # Spark Application
        # -----------------------------------------
        application="/opt/telstra/omega/internetrequestquery/current/irqf.jar",

        java_class="com.telstra.omega.process.omegaProcessRequest",

        name="omega-IRqF-internetRequest-iplogs",


        # -----------------------------------------
        # Spark properties file (contains 40 confs)
        # -----------------------------------------
        properties_file="/opt/telstra/omega/config/iplogs_spark.properties",


        # -----------------------------------------
        # Additional dependency jars
        # -----------------------------------------
        jars="""
/opt/telstra/omega/internetrequestquery/current/spark-internetRequest.jar,
/app/hbase/lib/hbase-client.jar,
/app/cluster-essentials/*
""",


        # -----------------------------------------
        # Files shipped to executors
        # -----------------------------------------
        files="""
/opt/telstra/omega/omega-common-files/log4j-irqf/irqf-IPLOGS-log4j-executor.properties,
/opt/telstra/omega/omega-common-files/log4j-irqf/irqf-IPLOGS-log4j-driver.properties,
/opt/hbase/conf/hbase-site.xml
""",


        # -----------------------------------------
        # Spark resources
        # -----------------------------------------
        executor_memory="5g",

        executor_cores=2,

        num_executors=3,


        # -----------------------------------------
        # Environment variables
        # -----------------------------------------
        env_vars=env_vars,


        # -----------------------------------------
        # Debug logs
        # -----------------------------------------
        verbose=True

    )


