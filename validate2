📄 Example iplogs_spark.properties

Create file:

/opt/telstra/omega/config/iplogs_spark.properties

Example (put your 40 configs here):

spark.executor.memory=5g
spark.executor.instances=3
spark.executor.cores=2

spark.driver.memory=4g
spark.driver.maxResultSize=2g

spark.kafka.topic.input=OMEGA-TEST-IPLOGS-REQUEST
spark.kafka.topic.output=OMEGA-TEST-QUERY-RESPONSE

spark.streaming.backpressure.enabled=true
spark.streaming.kafka.maxRetries=10

spark.executor.heartbeatInterval=60s
spark.network.timeout=600s

spark.sql.parquet.compression.codec=snappy

spark.yarn.maxAppAttempts=4
spark.yarn.submit.waitAppCompletion=false

spark.debug.maxToStringFields=2147483640


